#!/bin/bash
# TAT pre-commit hook — blocks non-plan commits on main + branch name check
# Install: cp hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

BRANCH=$(git branch --show-current)

# --- Branch naming check (warning only) ---
# Valid: tat/<TASK-ID>-<slug>, docs/<slug>, fix/<slug>, chore/<slug>
if [ "$BRANCH" != "main" ]; then
  VALID_BRANCH=false
  case "$BRANCH" in
    tat/[a-zA-Z]*-[0-9]*) VALID_BRANCH=true ;;  # tat/tat-101-foo, tat/om-080-bar
    docs/*|fix/*|chore/*) VALID_BRANCH=true ;;    # non-task branches
  esac

  if [ "$VALID_BRANCH" = false ]; then
    echo ""
    echo "[TAT] Warning: branch name does not follow convention."
    echo ""
    echo "  Expected: tat/<TASK-ID>-<slug>"
    echo "  Example:  tat/tat-101-update-spec"
    echo "  Also OK:  docs/<slug>, fix/<slug>, chore/<slug>"
    echo ""
    echo "  Got: $BRANCH"
    echo ""
  fi
fi

if [ "$BRANCH" = "main" ]; then
  # Check staged files — only .tat/ workflow metadata is allowed on main
  # This includes: plan.md, lessons.md, decisions/, spec.md, alignment logs
  # Code changes (agent/, tests/, cli.py, etc.) must go through branches + PRs
  STAGED=$(git diff --cached --name-only)
  ONLY_TAT_METADATA=true

  for file in $STAGED; do
    case "$file" in
      .tat/*) ;; # All .tat/ files are workflow metadata — allowed
      docs/MAP.md) ;; # Spec→docs traceability map — allowed
      *) ONLY_TAT_METADATA=false; break ;;
    esac
  done

  if [ "$ONLY_TAT_METADATA" = true ]; then
    exit 0
  fi

  echo ""
  echo "[TAT] Committing to main is not allowed."
  echo ""
  echo "  TAT workflow: create a branch first → code → review → PR → merge"
  echo "  Allowed on main: .tat/ metadata (plan, lessons, decisions, spec)"
  echo ""
  echo "  Staged files:"
  echo "$STAGED" | sed 's/^/    /'
  echo ""
  echo "  Create a branch:  git checkout -b tat/<TASK-ID>-<slug>"
  echo "  Override:          TAT_FORCE=1 git commit ..."
  echo ""

  if [ "${TAT_FORCE:-0}" = "1" ]; then
    exit 0
  fi
  exit 1
fi
